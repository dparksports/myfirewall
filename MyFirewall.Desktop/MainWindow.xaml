<Window x:Class="MyFirewall.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MyFirewall.Desktop.ViewModels"
        Title="TCP Monitor" Height="768" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}"
        Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI, Inter"
        Closed="Window_Closed">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="15" CornerRadius="8" Background="{DynamicResource BgSecondary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <!-- Shield Icon (text placeholder) -->
                    <TextBlock Text="🛡" FontSize="20" Foreground="{DynamicResource AccentCyan}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="TCP Monitor" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource StatusRed}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitorActive}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource StatusGreen}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Network Monitor" Foreground="{DynamicResource TextSecondary}" Margin="0,0,20,0"/>
                    
                    <TextBlock Text="{Binding ConnectionCount}" FontWeight="Bold" Foreground="{DynamicResource AccentCyan}" Margin="0,0,5,0"/>
                    <TextBlock Text="Connections" Foreground="{DynamicResource TextSecondary}" Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding BlockedCount}" FontWeight="Bold" Foreground="{DynamicResource StatusRed}" Margin="0,0,5,0"/>
                    <TextBlock Text="Blocked" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid Card -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,5,0">
                <DataGrid ItemsSource="{Binding Connections}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <TextBlock>
                                        <Run Text="PID: " FontWeight="Bold"/>
                                        <Run Text="{Binding PID}"/>
                                        <LineBreak/>
                                        <Run Text="Raw IP: " FontWeight="Bold"/>
                                        <Run Text="{Binding Destination}"/>
                                    </TextBlock>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu Background="{DynamicResource BgSecondary}" Foreground="{DynamicResource TextPrimary}">
                                        <MenuItem Header="Block this address" Command="{Binding DataContext.BlockIPCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  CommandParameter="{Binding Destination}"/>
                                        <MenuItem Header="Hide this app" Command="{Binding DataContext.IgnoreAppCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  CommandParameter="{Binding ApplicationName}"/>
                                        <MenuItem Header="Stop this app" Command="{Binding DataContext.StopAppCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  CommandParameter="{Binding PID}" Foreground="{DynamicResource StatusRed}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" ToolTip="Status Indicator" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Application" Binding="{Binding ApplicationName}" FontWeight="SemiBold" Width="*"/>
                        <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" Width="120"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="140"/>
                        <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="160"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80"/>
                        <DataGridTextColumn Header="↑ Upload" Binding="{Binding Upload}" Width="80" ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                        <DataGridTextColumn Header="↓ Download" Binding="{Binding Download}" Width="80" ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Sidebar -->
            <Grid Grid.Column="1" Margin="5,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <!-- Blocked IPs -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Blocked Addresses" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        
                        <ListBox Grid.Row="1" ItemsSource="{Binding BlockedIPs}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Vertical">
                                            <TextBlock Text="{Binding IP}" Foreground="{DynamicResource StatusRed}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Application}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondary}"
                                                Command="{Binding DataContext.UnblockIPCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding IP}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Ignored Apps -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,5,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Ignored Applications" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        
                        <ListBox Grid.Row="1" ItemsSource="{Binding IgnoredApps}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Application}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Restore" Padding="5,2" Background="#21262D" BorderBrush="{DynamicResource BorderColor}" Foreground="{DynamicResource TextPrimary}"
                                                Command="{Binding DataContext.UnignoreAppCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding Application}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Alert Bar -->
        <Border Grid.Row="2" Margin="0,10,0,0" Padding="15,10" CornerRadius="8" Background="{DynamicResource BgSecondary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Recent Alerts:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Alerts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A1616" BorderBrush="#5C1F1F" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                <TextBlock>
                                    <Run Text="{Binding Timestamp}" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                    <Run Text="{Binding Message}" Foreground="{DynamicResource StatusRed}"/>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Grid.Column="2" Content="Clear" Command="{Binding ClearAlertsCommand}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentCyan}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

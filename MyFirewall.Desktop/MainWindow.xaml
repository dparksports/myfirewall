<Window x:Class="MyFirewall.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MyFirewall.Desktop.ViewModels"
        Title="TCP Monitor" Height="820" Width="1320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MinWidth="900" MinHeight="600"
        FontFamily="Segoe UI, Inter"
        Closed="Window_Closed">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Main window border with rounded corners -->
    <Border Background="{DynamicResource BgPrimary}" CornerRadius="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- Custom Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Stats Dashboard -->
                <RowDefinition Height="Auto"/> <!-- Search Bar -->
                <RowDefinition Height="*"/>    <!-- Main Content -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>


            <!-- ═══════════════════════════════════════════════════════
                 ROW 0: CUSTOM TITLE BAR
                 ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondary}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="🛡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="TCP Monitor" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Desktop" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="6,0,0,0" VerticalAlignment="Center"/>

                        <!-- Admin Shield Badge -->
                        <Border Margin="12,0,0,0" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#2A1616"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                            <Setter Property="Background" Value="#0D2A16"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔒" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock FontSize="10" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Text" Value="No Admin"/>
                                            <Setter Property="Foreground" Value="{StaticResource StatusRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                    <Setter Property="Text" Value="Admin"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StatusGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Window Chrome Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="─" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click"/>
                        <Button Content="□" Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" x:Name="MaximizeBtn"/>
                        <Button Content="✕" Style="{StaticResource ChromeCloseButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════════════════
                 ROW 1: STATS DASHBOARD
                 ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Margin="12,8,12,0" Padding="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Connections -->
                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="CONNECTIONS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ConnectionCount}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource AccentCyan}"/>
                        </StackPanel>
                    </Border>

                    <!-- Blocked -->
                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="BLOCKED" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BlockedCount}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource StatusRed}"/>
                        </StackPanel>
                    </Border>

                    <!-- Upload -->
                    <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="↑ UPLOAD" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalUpload}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusGreen}"/>
                        </StackPanel>
                    </Border>

                    <!-- Download -->
                    <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="↓ DOWNLOAD" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalDownload}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusAmber}"/>
                        </StackPanel>
                    </Border>

                    <!-- FW Rules -->
                    <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="FW RULES" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding FirewallRuleCount}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource AccentPurple}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════════════════
                 ROW 2: SEARCH / TOOLBAR
                 ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Margin="16,10,16,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Field -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <TextBox x:Name="SearchBox" Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                                 VerticalAlignment="Center"/>
                        <!-- Placeholder text -->
                        <TextBlock Text="🔍  Search connections by app, IP, domain, or location..."
                                   IsHitTestVisible="False" VerticalAlignment="Center"
                                   Margin="14,0,0,0" FontSize="13"
                                   Foreground="{DynamicResource TextMuted}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Strategy Selector -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,20,0">
                        <TextBlock Text="🎯 Threat Intel Strategy:" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,8,0"/>
                        <RadioButton Content="Connection-Driven" IsChecked="{Binding IsConnectionDriven}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11" Cursor="Hand"/>
                        <RadioButton Content="Proactive ETW (WebView2)" IsChecked="{Binding IsProcessStartEtw}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" FontSize="11" Cursor="Hand"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource GhostButton}" Margin="0,0,4,0"/>
                        <Button Content="📋 Export" Command="{Binding ExportLogCommand}" Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════════════════
                 ROW 3: MAIN CONTENT (DataGrid + Sidebar)
                 ═══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3" Margin="12,4,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- DataGrid Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                    <DataGrid ItemsSource="{Binding Connections}" SelectedItem="{Binding SelectedConnection, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <StackPanel Margin="4">
                                            <TextBlock>
                                                <Run Text="PID: " FontWeight="Bold"/>
                                                <Run Text="{Binding PID, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="Remote: " FontWeight="Bold"/>
                                                <Run Text="{Binding Destination, Mode=OneWay}"/>
                                                <Run Text="{Binding PortDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="Local Port: " FontWeight="Bold"/>
                                                <Run Text="{Binding LocalPort, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="Domain: " FontWeight="Bold"/>
                                                <Run Text="{Binding Domain, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <!-- Fix: Pass both IP and AppName for proper blocking -->
                                            <MenuItem Header="🛑  Block this address"
                                                      Command="{Binding PlacementTarget.Tag.BlockIPCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="👁  Hide this app"
                                                      Command="{Binding PlacementTarget.Tag.IgnoreAppCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ApplicationName}"/>
                                            <MenuItem Header="⏹  Stop this app"
                                                      Command="{Binding PlacementTarget.Tag.StopAppCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PID}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <!-- Highlight blocked rows -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                        <Setter Property="Background" Value="#1A0F0F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- Status Dot -->
                            <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" HorizontalAlignment="Center">
                                            <Ellipse.ToolTip>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Setter Property="Text" Value="Active"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                    <Setter Property="Text" Value="Blocked"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Ellipse.ToolTip>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Application Name -->
                            <DataGridTextColumn Header="Application" Binding="{Binding DisplayProcessName}" FontWeight="SemiBold" Width="*" MinWidth="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGhosted}" Value="True">
                                                <Setter Property="Opacity" Value="0.6"/>
                                                <Setter Property="ToolTip" Value="{Binding GhostTooltip}"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Destination with port -->
                            <DataGridTemplateColumn Header="Destination" Width="150" SortMemberPath="Destination">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Destination, Mode=OneWay}"/>
                                            <Run Text="{Binding PortDisplay, Mode=OneWay}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Location with flag -->
                            <DataGridTemplateColumn Header="Location" Width="160" SortMemberPath="Location">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding CountryFlag, Mode=OneWay}" FontSize="13"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Location, Mode=OneWay}" Foreground="{DynamicResource AccentPurple}" FontSize="12"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Domain -->
                            <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="170" Foreground="{DynamicResource AccentCyan}"/>

                            <!-- Duration -->
                            <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80"/>

                            <!-- Upload -->
                            <DataGridTemplateColumn Header="↑ Upload" Width="85" SortMemberPath="UploadBytes">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Upload}" Foreground="{DynamicResource StatusGreen}" FontWeight="Medium"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Download -->
                            <DataGridTemplateColumn Header="↓ Download" Width="85" SortMemberPath="DownloadBytes">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Download}" Foreground="{DynamicResource StatusAmber}" FontWeight="Medium"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- ═══════════════════════════════════════════════
                     SIDEBAR
                     ═══════════════════════════════════════════════ -->
                <Grid Grid.Column="1" Margin="6,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto" MaxHeight="200"/>
                    </Grid.RowDefinitions>

                    <!-- Blocked IPs Panel -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header with count badge -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="🚫" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Blocked Addresses" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource CountBadge}">
                                    <TextBlock Text="{Binding BlockedCount}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource StatusRed}"/>
                                </Border>
                            </StackPanel>

                            <ListBox Grid.Row="1" ItemsSource="{Binding BlockedIPs}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding IP}" Foreground="{DynamicResource StatusRed}" FontWeight="SemiBold" FontSize="12"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Application}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Text=" • " FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Text="{Binding DisplayTimestamp}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                                                    Style="{StaticResource GhostButton}" FontSize="11"
                                                    Command="{Binding DataContext.UnblockIPCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding IP}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Ignored Apps Panel -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="👁" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Hidden Apps" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource CountBadge}">
                                    <TextBlock Text="{Binding IgnoredApps.Count}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                            </StackPanel>

                            <ListBox Grid.Row="1" ItemsSource="{Binding IgnoredApps}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Application}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" FontSize="12"/>
                                            <Button Grid.Column="1" Content="Restore" Padding="8,3" FontSize="11"
                                                    Command="{Binding DataContext.UnignoreAppCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding Application}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- System Controls Panel -->
                    <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="⚙" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="System Controls" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1">
                                <CheckBox Content="Language Sync" IsChecked="{Binding IsLanguageSyncEnabled}" Margin="0,4"/>
                                <CheckBox Content="Windows Widgets" IsChecked="{Binding IsWidgetsEnabled}" Margin="0,4"/>
                                <CheckBox Content="SearchHost Box" IsChecked="{Binding IsSearchHostEnabled}" Margin="0,4"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Recent Alerts Panel -->
                    <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Alerts" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding Alerts.Count}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource StatusAmber}"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Clear" Style="{StaticResource GhostButton}" FontSize="11"
                                        Command="{Binding ClearAlertsCommand}" Foreground="{DynamicResource AccentCyan}"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Alerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding AlertBgColor}" BorderBrush="{Binding AlertBorderColor}"
                                                    BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding AlertIcon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Top"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Message}" Foreground="{Binding AlertColor}" FontSize="11" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══════════════════════════════════════════════
                     SELECTED CONNECTION DETAILS DRAWER
                     ═══════════════════════════════════════════════ -->
                <Border Grid.Column="2" Width="300" Margin="6,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedConnection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with close button -->
                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock Text="🛡" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Process Intelligence" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource AccentCyan}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕" Width="20" Height="20" Style="{StaticResource GhostButton}" FontSize="10" Command="{Binding DeselectConnectionCommand}" VerticalAlignment="Center"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Application Name -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="APPLICATION" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding SelectedConnection.ApplicationName}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="{Binding SelectedConnection.PID, StringFormat='PID: {0}'}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>

                                <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                                <!-- Process Ancestry -->
                                <StackPanel Margin="0,8,0,12">
                                    <TextBlock Text="PROCESS ANCESTRY" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding SelectedConnection.Ancestry}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="↳ " Foreground="{DynamicResource AccentCyan}" FontSize="12" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding PID, StringFormat=' (PID {0})'}" Foreground="{DynamicResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Fallback if Ancestry is empty -->
                                    <TextBlock Text="{Binding SelectedConnection.ParentProcessName}" FontSize="11" Foreground="{DynamicResource TextMuted}" FontStyle="Italic">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedConnection.Ancestry.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                                <!-- Digital Signature -->
                                <StackPanel Margin="0,8,0,12">
                                    <TextBlock Text="DIGITAL SIGNATURE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding SelectedConnection.Signature}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusAmber}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedConnection.Signature}" Value="Unsigned">
                                                        <Setter Property="Foreground" Value="{StaticResource StatusRed}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedConnection.Signature}" Value="Unsigned / Unknown">
                                                        <Setter Property="Foreground" Value="{StaticResource StatusRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                                <!-- Location -->
                                <StackPanel Margin="0,8,0,12">
                                    <TextBlock Text="LOCATION (EXECUTABLE PATH)" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding SelectedConnection.ExecutablePath, Mode=OneWay}" Foreground="{DynamicResource TextSecondary}" FontSize="11" Background="Transparent" BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap" Padding="0"/>
                                </StackPanel>

                                <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                                <!-- Last Modified -->
                                <StackPanel Margin="0,8,0,12">
                                    <TextBlock Text="LAST MODIFIED DATE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding SelectedConnection.LastModified}" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>

                                <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                                <!-- Traffic Info -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="UPLOAD" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding SelectedConnection.Upload}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource StatusGreen}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="DOWNLOAD" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding SelectedConnection.Download}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource StatusAmber}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>


            <!-- ═══════════════════════════════════════════════════════
                 ROW 4: STATUS BAR
                 ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="4" Background="{DynamicResource BgSecondary}" CornerRadius="0,0,10,10"
                    Padding="16,6" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ETW Status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource StatusRed}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMonitorActive}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource StatusGreen}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Uptime -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="Uptime: " FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UptimeDisplay}" FontSize="11" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Refresh Interval -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="Refresh: " FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding RefreshInterval, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="11" Width="30" Height="18" Padding="2,0" 
                                 Background="Transparent" BorderThickness="0,0,0,1" 
                                 BorderBrush="{DynamicResource BorderSubtle}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                        <TextBlock Text="s" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Last Refresh -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Last refresh: " FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LastRefreshTime}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock Grid.Column="4" Text="v5.0" FontSize="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
